# ── Моды — бинарники, хранятся отдельно от git ───────────────────────────────
mods/*.jar

# ── Игровые данные (не нужны для сборки) ─────────────────────────────────────
saves/
backups/
screenshots/
schematics/
crash-reports/
logs/
*.log

# ── Кэш пользователей ────────────────────────────────────────────────────────
usercache.json
usernamecache.json

# ── Временные и локальные файлы ───────────────────────────────────────────────
local/
modernfix/
journeymap/
rhino.local.properties
options.txt

# Generated after Visual Keybinder applies the bundled first-start preset.
visual_keybinder/initialized.dat

# ── Patchouli runtime данные (генерируется в игре) ────────────────────────────
patchouli_data.json

# ── Отключённые моды (бэкапы, не нужны) ──────────────────────────────────────
*.disabled
*.bak
*.tmp
*.rar
*.zip
*.7z

# Packaged resource packs are release assets, not temporary archives.
!resourcepacks/
!resourcepacks/*.zip

# Per-user runtime data and extracted tool caches.
config/jei/world/
config/spark/activity.json
config/worldedit/.archive-unpack/
immersive_paintings/
immersive_paintings_cache/

# ── OS / IDE мусор ────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
.idea/
*.iml

# ── Документация (внутренняя, не для игры) ────────────────────────────────────
*.md
