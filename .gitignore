# ── Моды — бинарники, хранятся отдельно от git ───────────────────────────────
mods/*.jar

# ── Игровые данные (не нужны для сборки) ─────────────────────────────────────
saves/
backups/
screenshots/
schematics/
crash-reports/
logs/
*.log

# ── Кэш пользователей ────────────────────────────────────────────────────────
usercache.json
usernamecache.json

# ── Временные и локальные файлы ───────────────────────────────────────────────
local/
modernfix/
journeymap/
rhino.local.properties
options.txt

# ── Patchouli runtime данные (генерируется в игре) ────────────────────────────
patchouli_data.json

# ── Отключённые моды (бэкапы, не нужны) ──────────────────────────────────────
*.disabled
*.bak
*.tmp
*.rar
*.zip
*.7z

# ── OS / IDE мусор ────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
.idea/
*.iml

# ── Документация (внутренняя, не для игры) ────────────────────────────────────
*.md
